# Bỏ chặn thư mục .pio và các thư mục con để Git có thể tìm vào bên trong
!.pio/
!.pio/build/
!.pio/build/esp32doit-devkit-v1/

# Chặn tất cả mọi thứ bên trong thư mục build này
.pio/build/esp32doit-devkit-v1/*

# NHƯNG ngoại lệ cho file firmware.bin (dấu ! nghĩa là không chặn)
!.pio/build/esp32doit-devkit-v1/firmware.bin
.vscode/.browse.c_cpp.db*
.vscode/c_cpp_properties.json
.vscode/launch.json
.vscode/ipch
